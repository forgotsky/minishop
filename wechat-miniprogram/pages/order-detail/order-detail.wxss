/* order-detail styles */
.container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.status-card {
  background: linear-gradient(135deg, #07c160, #10b980);
  color: #fff;
  border-radius: 16rpx;
  padding: 40rpx 24rpx;
  margin-bottom: 20rpx;
}
.status-text {
  font-size: 40rpx;
  font-weight: bold;
}
.order-info {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.order-info text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.address-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.address-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.address-detail {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
}

.item-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}
.item-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background: #eee;
  flex-shrink: 0;
}
.item-detail {
  flex: 1;
  margin-left: 20rpx;
}
.item-name {
  font-size: 28rpx;
  color: #333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 360rpx;
}
.item-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}
.item-subtotal {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #666;
}
.discount { color: #07c160; }
.total-row {
  border-top: 2rpx solid #eee;
  margin-top: 8rpx;
  padding-top: 16rpx;
  font-weight: bold;
  color: #333;
}
.total-price {
  font-size: 36rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.tracking-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.tracking-company {
  font-size: 28rpx;
  color: #333;
}
.tracking-number {
  font-size: 24rpx;
  color: #999;
}
.tracking-tip {
  font-size: 24rpx;
  color: #07c160;
}

.action-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx 0;
}
.btn-primary {
  background: #07c160;
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 0 48rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}
.btn-danger {
  background: #fff;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
  border-radius: 40rpx;
  padding: 0 48rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}
.btn-default {
  background: #fff;
  color: #666;
  border: 2rpx solid #ddd;
  border-radius: 40rpx;
  padding: 0 48rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 100rpx;
  color: #999;
  font-size: 28rpx;
}