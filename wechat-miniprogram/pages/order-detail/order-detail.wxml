<view class="container" wx:if="{{order}}">
  <view class="card" style="text-align:center">
    <text class="tag {{order.status === 'paid' ? 'tag-green' : 'tag-red'}}" style="font-size:28rpx;padding:8rpx 24rpx">{{order.status}}</text>
    <view style="font-size:44rpx;font-weight:bold;margin-top:16rpx" class="price">{{order.payment_amount}}</view>
    <view style="font-size:24rpx;color:#999;margin-top:8rpx">Order: {{order.order_no}}</view>
  </view>

  <view class="card">
    <view style="font-weight:bold;margin-bottom:16rpx">Items</view>
    <view wx:for="{{order.items}}" wx:key="id" class="flex-between mt-10">
      <text>{{item.product_name}} x{{item.quantity}}</text>
      <text class="price">{{item.product_price * item.quantity}}</text>
    </view>
  </view>

  <view class="card">
    <view style="font-weight:bold;margin-bottom:16rpx">Price Details</view>
    <view class="flex-between mt-10"><text>Subtotal</text><text class="price">{{order.total_amount}}</text></view>
    <view class="flex-between mt-10"><text>Discount</text><text style="color:#07c160">-${{order.discount_amount}}</text></view>
    <view class="flex-between mt-10"><text>Delivery</text><text class="price">{{order.delivery_fee}}</text></view>
    <view class="flex-between mt-10" style="border-top:2rpx solid #eee;padding-top:16rpx;font-weight:bold">
      <text>Paid</text><text class="price" style="font-size:32rpx">{{order.payment_amount}}</text>
    </view>
  </view>

  <button wx:if="{{order.status === 'pending'}}" class="btn" style="width:100%;margin-top:20rpx" bindtap="onPay">Pay Now</button>
</view>
<view wx:else class="loading">Loading...</view>
