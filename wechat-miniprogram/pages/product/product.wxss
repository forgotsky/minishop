.detail-img { width: 100%; height: 500rpx; background: var(--color-border); }
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; gap: 20rpx; padding: 20rpx 30rpx; background: var(--color-card);
  box-shadow: 0 -2rpx 12rpx var(--color-shadow);
}
.bottom-bar button { margin: 0; }
