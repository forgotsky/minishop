.address-item { background: var(--color-input-bg); padding: 16rpx; border-radius: 12rpx; }
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center; padding: 20rpx 30rpx; background: var(--color-card);
  box-shadow: 0 -2rpx 12rpx var(--color-shadow);
}
.bottom-bar button { margin: 0; }
