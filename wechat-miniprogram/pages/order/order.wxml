<view class="container">
  <!-- Tabs -->
  <scroll-view scroll-x class="tabs">
    <view class="tab-list">
      <view wx:for="{{tabs}}" wx:key="*this" class="tab {{currentTab === item ? 'active' : ''}}" data-value="{{item}}" bindtap="onTabTap">{{STATUS_LABELS[item]}}</view>
    </view>
  </scroll-view>

  <!-- Empty -->
  <view wx:if="{{orders.length === 0 && !loading}}" class="empty">暂无订单</view>

  <!-- Order List -->
  <block wx:for="{{orders}}" wx:key="id">
    <view class="card" bindtap="onOrderTap" data-id="{{item.id}}">
      <view class="flex-between">
        <text class="order-no">{{item.order_no}}</text>
        <text class="status-tag status-{{item.status}}">{{STATUS_LABELS[item.status]}}</text>
      </view>
      <view class="item-preview" wx:if="{{item.first_item}}">
        <image class="item-img" src="{{item.first_item.image || '/images/placeholder.png'}}" mode="aspectFill"/>
        <view class="item-info">
          <text class="item-name">{{item.first_item.name}}</text>
          <text class="item-count">共{{item.items_count}}件商品</text>
        </view>
      </view>
      <view class="flex-between" style="margin-top:16rpx;padding-top:16rpx;border-top:2rpx solid #f5f5f5">
        <text class="order-time">{{item.created_at}}</text>
        <text class="price">¥{{item.payment_amount}}</text>
      </view>
    </view>
  </block>

  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading">加载中...</view>
  <view wx:if="{{!hasMore && orders.length > 0}}" class="no-more">— 没有更多了 —</view>
</view>