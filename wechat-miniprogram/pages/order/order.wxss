/* order list page */
.tabs {
  background: #fff;
  white-space: nowrap;
  padding: 0 24rpx;
}
.tab-list {
  display: flex;
  align-items: center;
}
.tab {
  display: inline-block;
  padding: 24rpx 20rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}
.tab.active {
  color: #07c160;
  font-weight: bold;
  border-bottom: 4rpx solid #07c160;
}

.container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-no {
  font-size: 24rpx;
  color: #999;
}

.status-tag {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.status-pending { background: #fff7e6; color: #fa8c16; }
.status-paid { background: #e6f7ff; color: #1890ff; }
.status-shipped { background: #f0f5ff; color: #597ef7; }
.status-delivered { background: #f6ffed; color: #52c41a; }
.status-completed { background: #f6ffed; color: #52c41a; }
.status-cancelled { background: #f5f5f5; color: #999; }

.item-preview {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 16rpx;
  background: #fafafa;
  border-radius: 12rpx;
}
.item-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background: #eee;
  flex-shrink: 0;
}
.item-info {
  margin-left: 20rpx;
  flex: 1;
}
.item-name {
  font-size: 28rpx;
  color: #333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}
.item-count {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.price {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading, .no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 24rpx;
}