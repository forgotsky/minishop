<view class="page" wx:if="{{activeCategory && activeSkill}}">
  <view class="card panel">
    <view class="panel-title">分类选择</view>
    <picker mode="selector" range="{{categories}}" range-key="categoryName" value="{{categoryIndex}}" bindchange="onCategoryChange">
      <view class="picker">当前分类：{{activeCategory.categoryName}}（{{activeCategory.stage}}）</view>
    </picker>

    <view class="sub-title">Top3技能</view>
    <view class="chip-wrap">
      <block wx:for="{{activeCategory.topSkills}}" wx:key="skillId" wx:for-item="skill">
        <view
          class="chip {{skill.skillId === activeSkillId ? 'chip-active' : ''}}"
          data-skill-id="{{skill.skillId}}"
          bindtap="onSkillChange"
        >{{skill.skillName}}</view>
      </block>
    </view>
  </view>

  <view class="card panel">
    <view class="section-title">{{activeSkill.skillName}}</view>
    <view class="desc">{{activeSkill.summary}}</view>

    <block wx:for="{{activeSkill.levels}}" wx:key="level" wx:for-item="level">
      <view class="level-box">
        <view class="level-title">{{level.level}} · {{level.title}}</view>
        <view class="level-objective">目标：{{level.objective}}</view>
        <view class="points-label">知识点：</view>
        <block wx:for="{{level.points}}" wx:key="*this" wx:for-item="point">
          <view class="point">- {{point}}</view>
        </block>
      </view>
    </block>
  </view>

  <view class="card panel" wx:if="{{activeSkill.levels[0].microSplit}}">
    <view class="section-title">L1 微切分学习任务</view>
    <view class="load">建议强度：{{activeSkill.levels[0].microSplit.dailyLoad}} ｜ {{activeSkill.levels[0].microSplit.hourlyLoad}}</view>

    <view class="mode-row">
      <view class="mode {{l1Mode === 'hour' ? 'mode-active' : ''}}" data-mode="hour" bindtap="onModeChange">按小时</view>
      <view class="mode {{l1Mode === 'day' ? 'mode-active' : ''}}" data-mode="day" bindtap="onModeChange">按天</view>
    </view>

    <view wx:if="{{l1Mode === 'hour'}}">
      <block wx:for="{{activeSkill.levels[0].microSplit.hourTasks}}" wx:key="slot" wx:for-item="hourTask">
        <view class="task">
          <view class="task-title">{{hourTask.slot}}</view>
          <view class="task-text">词汇：{{hourTask.wordsText}}</view>
          <view class="task-text">例句：{{hourTask.sentence}}</view>
          <view class="task-text">应用：{{hourTask.usage}}</view>
        </view>
      </block>
    </view>

    <view wx:if="{{l1Mode === 'day'}}">
      <block wx:for="{{activeSkill.levels[0].microSplit.dayTasks}}" wx:key="day" wx:for-item="dayTask">
        <view class="task">
          <view class="task-title">{{dayTask.day}}</view>
          <view class="task-text">学习目标：{{dayTask.target}}</view>
          <view class="task-text">验收标准：{{dayTask.deliverable}}</view>
        </view>
      </block>
    </view>
  </view>

  <view class="card panel">
    <view class="section-title">学习计划生成器</view>
    <view class="plan-row">
      <view class="plan-input">
        <view class="plan-label">每天可学(分钟)</view>
        <input
          type="number"
          value="{{dailyMinutes}}"
          bindinput="onDailyMinutesInput"
          class="input"
        />
      </view>
      <view class="plan-input">
        <view class="plan-label">每周学习天数</view>
        <input
          type="number"
          value="{{daysPerWeek}}"
          bindinput="onDaysPerWeekInput"
          class="input"
        />
      </view>
    </view>
    <button class="plan-btn" bindtap="generatePlan">生成周计划</button>

    <view wx:if="{{planView}}">
      <view class="progress">
        完成率：{{progressStats.rate}}%（{{progressStats.done}}/{{progressStats.total}}）
      </view>
      <block wx:for="{{planView.schedule}}" wx:key="day" wx:for-item="dayBlock">
        <view class="day-box">
          <view class="day-title">{{dayBlock.day}} · 预计{{dayBlock.minutes}}分钟</view>
          <block wx:for="{{dayBlock.tasks}}" wx:key="id" wx:for-item="task">
            <view class="task task-check {{task.done ? 'task-done' : ''}}" data-task-id="{{task.id}}" bindtap="toggleTaskDone">
              <view class="check">{{task.done ? '已完成' : '待完成'}}</view>
              <view class="task-title">{{task.title}}（{{task.estimateMin}}分钟）</view>
              <view class="task-text">词汇：{{task.wordsText}}</view>
              <view class="task-text">例句：{{task.sentence}}</view>
              <view class="task-text">应用：{{task.usage}}</view>
            </view>
          </block>
        </view>
      </block>
    </view>
  </view>
</view>
