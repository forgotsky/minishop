.tab {
  flex: 1; text-align: center; padding: 20rpx; font-size: 28rpx; border-bottom: 4rpx solid transparent;
  color: var(--color-text-secondary);
}
.tab.active { border-bottom-color: var(--color-primary); color: var(--color-primary); font-weight: bold; }
.coupon-card { border-left: 6rpx solid var(--color-coupon-border); }
