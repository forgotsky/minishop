<view class="container">
  <view class="flex-row" style="margin-bottom:20rpx">
    <view class="tab {{tab === 'mine' ? 'active' : ''}}" bindtap="setTab" data-tab="mine">My Coupons</view>
    <view class="tab {{tab === 'available' ? 'active' : ''}}" bindtap="setTab" data-tab="available">Get More</view>
  </view>

  <!-- My coupons -->
  <block wx:if="{{tab === 'mine'}}">
    <view wx:if="{{myCoupons.length === 0}}" class="empty">No coupons yet</view>
    <view wx:for="{{myCoupons}}" wx:key="id" class="coupon-card card">
      <view class="flex-between">
        <view>
          <view style="font-size:32rpx;font-weight:bold" class="price">{{item.template.value}}{{item.template.type === 'discount' ? '% Off' : ''}}</view>
          <view style="font-size:24rpx;color:#666;margin-top:6rpx">{{item.template.name}}</view>
        </view>
        <view class="tag {{item.status === 'unused' ? 'tag-green' : item.status === 'used' ? 'tag-gray' : 'tag-red'}}">{{item.status}}</view>
      </view>
      <view style="font-size:22rpx;color:#999;margin-top:8rpx">{{item.template.description || 'No min spend'}}</view>
    </view>
  </block>

  <!-- Available coupons -->
  <block wx:if="{{tab === 'available'}}">
    <view wx:for="{{available}}" wx:key="id" class="coupon-card card">
      <view class="flex-between">
        <view>
          <view style="font-size:32rpx;font-weight:bold" class="price">{{item.value}}{{item.type === 'discount' ? '% Off' : ''}}</view>
          <view style="font-size:24rpx;color:#666;margin-top:6rpx">{{item.name}}</view>
        </view>
        <button class="btn" size="mini" bindtap="onClaim" data-id="{{item.id}}">Claim</button>
      </view>
      <view style="font-size:22rpx;color:#999;margin-top:8rpx">{{item.description || 'No min spend'}}</view>
    </view>
  </block>
</view>
