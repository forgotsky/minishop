.search-bar {
  display: flex; gap: 16rpx; padding: 20rpx; background: var(--color-card);
  margin-bottom: 16rpx; border-radius: 16rpx;
}
.search-bar input {
  flex: 1; background: var(--color-input-bg); border-radius: 12rpx; padding: 14rpx 20rpx; font-size: 28rpx;
}
.lang-btn {
  margin-left: 8rpx;
}

.cat-scroll { white-space: nowrap; padding: 0 20rpx 16rpx; }
.cat-tag {
  display: inline-block; padding: 10rpx 24rpx; margin-right: 12rpx;
  border-radius: 999rpx; background: var(--color-card); font-size: 26rpx; color: var(--color-text-secondary);
}
.cat-tag.active { background: var(--color-primary); color: #fff; }

.theme-indicator {
  display: inline-block;
  width: 32rpx; height: 32rpx;
  border-radius: 50%;
  background: var(--color-primary);
  vertical-align: middle;
  margin-right: 6rpx;
  border: 2rpx solid var(--color-border);
}

.product-grid { display: flex; flex-wrap: wrap; padding: 0 10rpx; }
.product-card {
  width: calc(50% - 40rpx); margin: 0 10rpx 20rpx; overflow: hidden;
}
.product-img { width: 100%; height: 280rpx; border-radius: 12rpx; background: var(--color-border); }
.product-name { font-size: 28rpx; font-weight: 500; margin-top: 12rpx; }
.product-info { padding: 16rpx 6rpx 0; }
.product-info .price { font-size: 32rpx; margin-top: 8rpx; }

.load-more { text-align: center; padding: 20rpx; }
