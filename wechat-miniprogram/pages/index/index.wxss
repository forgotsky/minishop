.search-bar {
  display: flex; gap: 16rpx; padding: 20rpx; background: #fff;
  margin-bottom: 16rpx; border-radius: 16rpx;
}
.search-bar input {
  flex: 1; background: #f5f5f5; border-radius: 12rpx; padding: 14rpx 20rpx; font-size: 28rpx;
}

.cat-scroll { white-space: nowrap; padding: 0 20rpx 16rpx; }
.cat-tag {
  display: inline-block; padding: 10rpx 24rpx; margin-right: 12rpx;
  border-radius: 999rpx; background: #fff; font-size: 26rpx; color: #666;
}
.cat-tag.active { background: #ff5500; color: #fff; }

.product-grid { display: flex; flex-wrap: wrap; padding: 0 10rpx; }
.product-card {
  width: calc(50% - 40rpx); margin: 0 10rpx 20rpx; overflow: hidden;
}
.product-img { width: 100%; height: 280rpx; border-radius: 12rpx; background: #eee; }
.product-name { font-size: 28rpx; font-weight: 500; margin-top: 12rpx; }
.product-info { padding: 16rpx 6rpx 0; }
.product-info .price { font-size: 32rpx; margin-top: 8rpx; }

.load-more { text-align: center; padding: 20rpx; }
