  --color-border:        #e8e8e8;
  --color-border-light:  #f0f0f0;
  --color-danger:        #ff4d4f;
  --color-success:       #07c160;
  --color-navbar-bg:     #07c160;
  --color-tab-active:    #07c160;
  --color-tab-inactive:  #999999;
  --color-input-bg:      #f5faf5;
  --color-coupon-border: #07c160;
  --color-shadow:        rgba(0,0,0,0.06);
  --color-status-pending-bg:   #fff7e6;
  --color-status-pending-text: #fa8c16;
  --color-status-paid-bg:      #e6f7ff;
