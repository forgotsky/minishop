/* ============================================================
   MiniShop Theme System — 4 themes via CSS Custom Properties
   Works with WeChat mini-programs (base library 2.9.0+)
   Theme class goes on each page's root <view> element
   ============================================================ */

/* ---- Default: Classic Orange (经典橙) — no class needed ---- */
page {
  --color-primary:       #ff5500;
  --color-primary-light: #fff0f0;
  --color-bg:            #f5f5f5;
  --color-card:          #ffffff;
  --color-text:          #333333;
  --color-text-secondary:#666666;
  --color-text-muted:    #999999;
  --color-border:        #eeeeee;
  --color-border-light:  #f0f0f0;
  --color-danger:        #ff4d4f;
  --color-success:       #07c160;
  --color-navbar-bg:     #ff5500;
  --color-tab-active:    #ff5500;
  --color-tab-inactive:  #999999;
  --color-input-bg:      #f5f5f5;
  --color-coupon-border: #ff5500;
  --color-shadow:        rgba(0,0,0,0.06);
  /* status tag colors */
  --color-status-pending-bg:   #fff7e6;
  --color-status-pending-text: #fa8c16;
  --color-status-paid-bg:      #e6f7ff;
  --color-status-paid-text:    #1890ff;
  --color-status-shipped-bg:   #f0f5ff;
  --color-status-shipped-text: #597ef7;
  --color-status-completed-bg: #f6ffed;
  --color-status-completed-text:#52c41a;
  --color-status-cancelled-bg: #f5f5f5;
  --color-status-cancelled-text:#999999;
}

/* ---- Blue Theme (深海蓝) ---- */
