/* ---- Dark Theme (暗夜黑) ---- */
.theme-dark {
  --color-primary:       #d4a853;
  --color-primary-light: #3a3020;
  --color-bg:            #1a1a2e;
  --color-card:          #252540;
  --color-text:          #e8e8e8;
  --color-text-secondary:#aaaaaa;
  --color-text-muted:    #777777;
  --color-border:        #333344;
  --color-border-light:  #2a2a3a;
  --color-danger:        #ff6b6b;
  --color-success:       #52c41a;
  --color-navbar-bg:     #1a1a2e;
  --color-tab-active:    #d4a853;
  --color-tab-inactive:  #777777;
  --color-input-bg:      #1e1e32;
  --color-coupon-border: #d4a853;
  --color-shadow:        rgba(0,0,0,0.30);
  --color-status-pending-bg:   #3a3020;
  --color-status-pending-text: #d4a853;
  --color-status-paid-bg:      #1a2a3a;
  --color-status-paid-text:    #5ba0d0;
  --color-status-shipped-bg:   #2a2a3a;
  --color-status-shipped-text: #8a9af0;
  --color-status-completed-bg: #1a2a1a;
  --color-status-completed-text:#52c41a;
  --color-status-cancelled-bg: #2a2a2a;
  --color-status-cancelled-text:#777777;
}

/* ============================================================
   Brand-color navbar for light themes: force white text
   ============================================================ */
.theme-orange-page, .theme-blue-page, .theme-green-page {
  --nav-text-style: #ffffff;
}
.theme-dark-page {
  --nav-text-style: #e8e8e8;
}

/* ============================================================
   Global Styles — ALL use CSS variables
   ============================================================ */

page {
  background: var(--color-bg);
  font-size: 28rpx;
  color: var(--color-text);
}

.container {
  padding: 20rpx;
}

.card {
  background: var(--color-card);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx var(--color-shadow);
}

.price {
  color: var(--color-primary);
  font-weight: bold;
}
.price::before {
  content: '$';
  font-size: 24rpx;
}

.btn {
  background: var(--color-primary);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
}
.btn[disabled] {
  background: #ccc;
}

.btn-outline {
  background: var(--color-card);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: 12rpx;
  font-size: 28rpx;
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}
.tag-red {
  background: var(--color-primary-light);
  color: var(--color-primary);
}
.tag-green {
  background: #f0fff0;
  color: var(--color-success);
}
.tag-gray {
  background: var(--color-border-light);
  color: var(--color-text-muted);
}

.flex-row {
  display: flex;
  align-items: center;
}
.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.flex-1 {
  flex: 1;
}

.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mb-20 { margin-bottom: 20rpx; }

.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: var(--color-text-muted);
}
.empty {
  text-align: center;
  padding: 80rpx;
  color: var(--color-text-muted);
  font-size: 28rpx;
}
