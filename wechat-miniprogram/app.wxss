page { background: #f5f5f5; font-size: 28rpx; color: #333; }

.container { padding: 20rpx; }

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.price { color: #ff5500; font-weight: bold; }
.price::before { content: '$'; font-size: 24rpx; }

.btn {
  background: #ff5500;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
}
.btn[disabled] { background: #ccc; }

.btn-outline {
  background: #fff;
  color: #ff5500;
  border: 2rpx solid #ff5500;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}
.tag-red { background: #fff0f0; color: #ff5500; }
.tag-green { background: #f0fff0; color: #07c160; }
.tag-gray { background: #f0f0f0; color: #999; }

.flex-row { display: flex; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-1 { flex: 1; }

.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mb-20 { margin-bottom: 20rpx; }

.ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.loading { text-align: center; padding: 40rpx; color: #999; }
.empty { text-align: center; padding: 80rpx; color: #999; font-size: 28rpx; }
